  <property name="styleSheet">
   <string notr="true">QWidget#TiepNhanForm {
    background: #f6f9ff;
    font-family: &quot;Segoe UI&quot;;
    font-size: 14px;
    color: #111827;
}

QFrame#header {
    background: #ffffff;
    border: none;
    border-bottom: 1px solid #dfe7f3;
    border-radius: 0px;
}

QLabel {
    background: transparent;
    border: none;
    color: #111827;
}

QLabel#lblTitle {
    color: #0f6fd8;
    font-size: 25px;
    font-weight: 800;
}

QLabel#lblSubtitle {
    color: #1f2937;
    font-size: 14px;
    font-weight: 400;
}

QLabel#lblTaiKhoan {
    color: #111827;
    font-size: 14px;
    font-weight: 700;
}

QFrame#cardDaTiepNhan,
QFrame#cardDangCho,
QFrame#cardUuTien,
QFrame#cardThanhCong,
QFrame#panelThongTin,
QFrame#panelDanhSach,
QFrame#panelTongQuan,
QFrame#panelNhatKy {
    background: #ffffff;
    border: 1px solid #dfe7f3;
    border-radius: 7px;
}

QLabel#cardDaTiepNhanTitle,
QLabel#cardDangChoTitle,
QLabel#cardUuTienTitle,
QLabel#cardThanhCongTitle {
    color: #111827;
    font-size: 14px;
    font-weight: 600;
}

QLabel#lblKhachDaTiepNhanHomNay {
    color: #0f6fd8;
    font-size: 24px;
    font-weight: 800;
}

QLabel#lblSoKhachDangCho {
    color: #f59e0b;
    font-size: 24px;
    font-weight: 800;
}

QLabel#lblKhachUuTien {
    color: #e83e63;
    font-size: 24px;
    font-weight: 800;
}

QLabel#lblTiepNhanThanhCong {
    color: #15803d;
    font-size: 22px;
    font-weight: 800;
}

QLabel#lblTitleThongTin,
QLabel#lblTitleDanhSach,
QLabel#lblTitleTongQuan,
QLabel#lblTitleNhatKy {
    color: #155eb8;
    font-size: 15px;
    font-weight: 800;
}

QLabel#lblHoTen,
QLabel#lblDienThoai,
QLabel#lblLoaiDichVu,
QLabel#lblNhomKhach,
QLabel#lblMucUuTien,
QLabel#lblGhiChu {
    color: #111827;
    font-size: 14px;
    font-weight: 500;
}

QLineEdit,
QComboBox,
QTextEdit,
QPlainTextEdit {
    background: #ffffff;
    border: 1px solid #d7dfeb;
    border-radius: 5px;
    padding: 6px 8px;
    color: #111827;
    font-size: 14px;
}

QLineEdit:hover,
QComboBox:hover,
QTextEdit:hover,
QPlainTextEdit:hover {
    border: 1px solid #9bbcf0;
}

QLineEdit:focus,
QComboBox:focus,
QTextEdit:focus,
QPlainTextEdit:focus {
    border: 1px solid #0f73df;
}

QComboBox::drop-down {
    border: none;
    width: 26px;
}

QComboBox QAbstractItemView {
    background: #ffffff;
    color: #111827;
    border: 1px solid #d7dfeb;
    selection-background-color: #eef6ff;
    selection-color: #111827;
}

QPushButton {
    border-radius: 6px;
    font-family: &quot;Segoe UI&quot;;
    font-size: 14px;
    font-weight: 700;
}

QPushButton#btnDangXuat {
    background: #ffffff;
    color: #155eb8;
    border: 1px solid #bcd0ea;
    padding: 8px 16px;
    min-width: 112px;
    min-height: 40px;
}

QPushButton#btnDangXuat:hover {
    background: #eef6ff;
    border: 1px solid #8fb4e8;
}

QPushButton#btnThemKhach {
    background: #0f73df;
    color: white;
    border: 1px solid #0b63c7;
    padding: 8px 14px;
    min-width: 211px;
    min-height: 48px;
    font-size: 14px;
    font-weight: 800;
}

QPushButton#btnThemKhach:hover {
    background: #0b63c7;
}

QPushButton#btnThemKhach:pressed {
    background: #094f9f;
}

QPushButton#btnLamMoi {
    background: #ffffff;
    color: #155eb8;
    border: 1px solid #bcd0ea;
    padding: 8px 14px;
    min-width: 191px;
    min-height: 48px;
    font-size: 14px;
    font-weight: 800;
}

QPushButton#btnLamMoi:hover {
    background: #eef6ff;
    border: 1px solid #8fb4e8;
}

QPushButton#btnLamMoi:pressed {
    background: #dcecff;
}

QPushButton#btnTaoSoThuTu {
    background: #ffffff;
    color: #15803d;
    border: 1px solid #8fd0aa;
    padding: 8px 14px;
    min-width: 231px;
    min-height: 48px;
    font-size: 14px;
    font-weight: 800;
}

QPushButton#btnTaoSoThuTu:hover {
    background: #ecfdf5;
    border: 1px solid #66c28a;
}

QPushButton#btnTaoSoThuTu:pressed {
    background: #daf7e7;
}

QLabel#lblThongBaoThanhCong {
    color: #15803d;
    background: #ecfdf5;
    border: 1px solid #d1fae5;
    border-radius: 5px;
    padding: 8px 10px;
    font-size: 14px;
    font-weight: 600;
}

QLabel#lblThongBaoThanhCong[status=&quot;error&quot;] {
    color: #dc2626;
    background: #fff1f2;
    border: 1px solid #fecdd3;
}

QLabel#lblQuyTac,
QLabel#lblLuuY {
    color: #155eb8;
    background: #eef6ff;
    border: 1px solid #d7e8fb;
    border-radius: 5px;
    padding: 6px 8px;
    font-size: 13px;
    font-weight: 500;
}

QTextEdit#txtTheoDoi {
    background: #ffffff;
    color: #111827;
    border: 1px solid #d7dfeb;
    border-radius: 5px;
    padding: 8px;
    font-family: &quot;Consolas&quot;;
    font-size: 13px;
}

QTableWidget {
    background: #ffffff;
    alternate-background-color: #fbfdff;
    border: 1px solid #e5eaf2;
    border-radius: 5px;
    gridline-color: #edf1f7;
    color: #111827;
    font-size: 13px;
    selection-background-color: #e8f1ff;
    selection-color: #111827;
}

QTableWidget::item {
    padding: 5px;
    border: none;
}

QTableWidget::item:selected {
    background: #e8f1ff;
    color: #111827;
}

QHeaderView::section {
    background: #ffffff;
    color: #111827;
    border: none;
    border-bottom: 1px solid #e5eaf2;
    padding: 7px;
    font-size: 13px;
    font-weight: 700;
}

QTableCornerButton::section {
    background: #ffffff;
    border: none;
}

QScrollBar:vertical {
    background: #f6f9ff;
    width: 10px;
    margin: 0px;
}

QScrollBar::handle:vertical {
    background: #c6d4e8;
    border-radius: 5px;
    min-height: 25px;
}

QScrollBar::handle:vertical:hover {
    background: #9fb5d3;
}

QScrollBar::add-line:vertical,
QScrollBar::sub-line:vertical {
    height: 0px;
}

QScrollBar:horizontal {
    background: #f6f9ff;
    height: 10px;
    margin: 0px;
}

QScrollBar::handle:horizontal {
    background: #c6d4e8;
    border-radius: 5px;
    min-width: 25px;
}

QScrollBar::handle:horizontal:hover {
    background: #9fb5d3;
}

QScrollBar::add-line:horizontal,
QScrollBar::sub-line:horizontal {
    width: 0px;
}</string>
