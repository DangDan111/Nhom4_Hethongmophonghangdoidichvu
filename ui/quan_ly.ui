  <property name="styleSheet">
   <string notr="true">QWidget {
    background: #f5f8ff;
}
QFrame {
    background: white;
    border: 1px solid #d9e2f2;
    border-radius: 8px;
}
QLabel {
    background: transparent;
    border: none;
    border-radius: 0px;
}
QLabel#lblTitle,
QLabel.sectionTitle {
    color: #0f5bd7;
    font-weight: 700;
}
QLabel.value {
    background: white;
    border: 1px solid #d9e2f2;
    border-radius: 8px;
    font-size: 26px;
    font-weight: 700;
    color: #0f5bd7;
    padding-left: 10px;
}

QPushButton {
    background: #0f5bd7;
    color: white;
    border-radius: 6px;
    font-weight: 700;
}

QPushButton#btnDangXuat,
QPushButton#btnSapXepBaoCao,
QPushButton#btnLamMoi {
    background: white;
    color: #0f5bd7;
    border: 1px solid #cbd5e1;
}

QPushButton#btnDongQuay {
    background: #ef4444;
    color: white;
}

QTableWidget {
    background: white;
    border: 1px solid #e5e7eb;
    gridline-color: #e5e7eb;
}

QComboBox {
    background: white;
    border: 1px solid #cbd5e1;
    border-radius: 6px;
    padding: 4px;
}</string>
