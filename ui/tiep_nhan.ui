  <property name="styleSheet">
   <string notr="true">
QWidget#TiepNhanForm {
    background: #f6f9ff;
    font-family: "Segoe UI";
    color: #111827;
}
QFrame {
    background: #ffffff;
    border: 1px solid #dfe7f3;
    border-radius: 7px;
}
QFrame#header {
    border-left: 0px;
    border-right: 0px;
    border-top: 0px;
    border-radius: 0px;
}
QLabel {
    background: transparent;
    border: none;
}
QLabel#lblTitle {
    color: #0f6fd8;
    font-size: 25px;
    font-weight: 800;
}
QLabel.sectionTitle {
    color: #155eb8;
    font-weight: 800;
}
QLabel.badgeGreen {
    color: #15803d;
    background: #ecfdf5;
    border: 1px solid #d1fae5;
    border-radius: 5px;
}
QLabel.badgeBlue {
    color: #155eb8;
    background: #eef6ff;
    border: 1px solid #d7e8fb;
    border-radius: 5px;
}
QLineEdit, QComboBox, QTextEdit {
    background: #ffffff;
    border: 1px solid #d7dfeb;
    border-radius: 5px;
    padding: 6px 8px;
    color: #111827;
}
QPushButton {
    border-radius: 6px;
    padding: 8px 10px;
    font-weight: 700;
}
QPushButton.primary {
    background: #0f73df;
    color: white;
    border: 1px solid #0b63c7;
}
QPushButton.secondary {
    background: #ffffff;
    color: #155eb8;
    border: 1px solid #bcd0ea;
}
QPushButton.success {
    background: #ffffff;
    color: #15803d;
    border: 1px solid #8fd0aa;
}
QTableWidget {
    background: #ffffff;
    alternate-background-color: #fbfdff;
    border: 0px;
    gridline-color: #edf1f7;
}
QHeaderView::section {
    background: #ffffff;
    border: 0px;
    border-bottom: 1px solid #e5eaf2;
    padding: 7px;
    font-weight: 700;
}
</string>
