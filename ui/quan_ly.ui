  <property name="styleSheet">
   <string notr="true">QWidget#QuanLyForm {
    background: #f6f9ff;
    font-family: &quot;Segoe UI&quot;;
    color: #111827;
}

QFrame {
    background: #ffffff;
    border: 1px solid #dfe7f3;
    border-radius: 8px;
}

QLabel {
    background: transparent;
    border: none;
}

QLabel#lblTitle {
    color: #0f6fd8;
    font-weight: 800;
    letter-spacing: 0px;
}

QLabel#lblSubtitle {
    color: #374151;
}

QLabel.sectionTitle {
    color: #155eb8;
    font-weight: 800;
}

QLabel.metricValue {
    font-weight: 800;
}

QLabel.iconCircle {
    min-width: 54px;
    min-height: 54px;
    max-width: 54px;
    max-height: 54px;
}

QPushButton {
    background: #0f73df;
    color: white;
    border: 1px solid #0b63c7;
    border-radius: 6px;
    padding: 7px 14px;
    font-weight: 700;
}

QPushButton#btnDangXuat,
QPushButton#btnSapXepBaoCao,
QPushButton#btnLamMoi {
    background: #ffffff;
    color: #155eb8;
    border: 1px solid #c8d6eb;
}

QPushButton#btnDongQuay {
    background: #ef4444;
    border-color: #dc2626;
}

QComboBox {
    background: #ffffff;
    border: 1px solid #c8d6eb;
    border-radius: 6px;
    padding-left: 10px;
    padding-right: 22px;
    padding-top: 0px;
    padding-bottom: 0px;
    min-height: 30px;
    max-height: 34px;
}

QComboBox::drop-down {
    border: none;
    width: 22px;
}

QTableWidget {
    background: #ffffff;
    alternate-background-color: #fbfdff;
    border: 0px;
    gridline-color: #edf1f7;
    selection-background-color: #dbeafe;
    selection-color: #111827;
}

QHeaderView::section {
    background: #ffffff;
    border: 0px;
    border-bottom: 1px solid #e5eaf2;
    padding: 8px 6px;
    font-weight: 700;
    color: #111827;
}

QFrame#cardTongDaPhucVu,
