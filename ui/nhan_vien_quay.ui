}
QTextEdit {
    background: #ffffff;
    border: 1px solid #d7dfeb;
    border-radius: 5px;
    padding: 8px;
    color: #111827;
}
QPushButton {
    border-radius: 6px;
    padding: 8px 10px;
    font-weight: 700;
}
QPushButton.primary {
    background: #0f73df;
    color: white;
    border: 1px solid #0b63c7;
}
QPushButton.success {
    background: #16a34a;
    color: white;
    border: 1px solid #15803d;
}
QPushButton.secondary {
    background: #ffffff;
    color: #155eb8;
    border: 1px solid #bcd0ea;
}
QTableWidget {
    background: #ffffff;
    alternate-background-color: #fbfdff;
    border: 0px;
    gridline-color: #edf1f7;
}
QHeaderView::section {
    background: #ffffff;
    border: 0px;
    border-bottom: 1px solid #e5eaf2;
    padding: 7px;
    font-weight: 700;
}
