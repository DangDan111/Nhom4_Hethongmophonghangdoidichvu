QWidget#NhanVienQuayForm {
    background: #f6f9ff;
    font-family: &quot;Segoe UI&quot;;
    color: #111827;
}
QFrame {
    background: #ffffff;
    border: 1px solid #dfe7f3;
    border-radius: 7px;
}
QFrame#header {
    border-left: 0px;
    border-right: 0px;
    border-top: 0px;
    border-radius: 0px;
}
QLabel {
    background: transparent;
    border: none;
}
QLabel#lblTitle {
    color: #0f6fd8;
    font-size: 25px;
    font-weight: 800;
}
QLabel.sectionTitle {
    color: #155eb8;
    font-weight: 800;
}
QLabel.badgeGreen {
    color: #15803d;
    background: #ecfdf5;
    border: 1px solid #d1fae5;
    border-radius: 5px;
}
QLabel.badgeBlue {
    color: #155eb8;
    background: #eef6ff;
    border: 1px solid #d7e8fb;
    border-radius: 5px;
}
QLabel.badgeRed {
    color: #dc2626;
    background: #fff1f2;
